{
  "manifest_version": 1,
  "name": "AniList Unicodifier Direct",
  "version": "1.0.0",
  "description": "Directly encodes unsupported Unicode in AniList status textareas.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://anilist.co/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://anilist.co/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html"
}
